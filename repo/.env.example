# PetMed Operations Suite — Environment Variables
# Copy this file to .env and customize for your environment.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_DB=petmed
POSTGRES_USER=petmed
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Backend
DATABASE_URL=postgresql://petmed:CHANGE_ME@db:5432/petmed
SESSION_SECRET=CHANGE_ME_random_64_char_string
ENCRYPTION_KEY=CHANGE_ME_32_char_hex_string
EVIDENCE_STORAGE_PATH=/app/evidence-storage
PORT=3020
HOST=0.0.0.0
NODE_ENV=production

# Frontend
API_BACKEND_URL=http://backend:3020
ORIGIN=http://localhost:5175

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5175
